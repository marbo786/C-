{
  "name": "antigravity-tracer",
  "publisher": "marbo786",
  "displayName": "Antigravity Tracer",
  "description": "A DevTools panel for AI coding agents — see what Antigravity did, in real time.",
  "version": "0.1.1",
  "repository": {
    "type": "git",
    "url": "https://github.com/marbo786/AG_Tracer"
  },
  "keywords": [
    "antigravity",
    "ai",
    "agent",
    "devtools",
    "tracer"
  ],
  "license": "MIT",
  "icon": "icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["Other"],
  "activationEvents": ["onStartupFinished"],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravityTracer.openPanel",
        "title": "Open Antigravity Tracer",
        "category": "Antigravity Tracer"
      }
    ]
  },
  "scripts": {
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:chokidar --external:sql.js --platform=node --format=cjs",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:chokidar --external:sql.js --platform=node --format=cjs --watch",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "chokidar": "^4.0.0",
    "sql.js": "^1.14.1"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.5.0",
    "rimraf": "^5.0.0",
    "esbuild": "^0.23.0",
    "@ag-tracer/collector": "*",
    "@ag-tracer/shared": "*"
  }
}
